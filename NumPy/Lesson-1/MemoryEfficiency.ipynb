    "# we check memory effiecy and which one is best in memory utilization\n",
    "import sys\n",
    "import numpy as np\n",
    "list1= list(range(1))\n",
    "arr=np.array(list1)\n",
    "print(\"python list size\" ,sys.getsizeof(list1)*len(list1) ,\"bytes\")\n",
    "print(\"python array size \" ,arr.nbytes ,\"bytes\")\n",
    "\n"
   ]
